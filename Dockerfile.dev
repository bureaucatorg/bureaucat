FROM golang:1.25.6-trixie

RUN set -ex \
  && apt update \
  && apt install -y \
    git \
    curl \
    bash \
    unzip \
  && go install "github.com/air-verse/air@v1.63.6" \
  && go install "github.com/sqlc-dev/sqlc/cmd/sqlc@v1.30.0" \
  && go install "github.com/swaggo/swag/cmd/swag@latest" \
  && curl -fsSL https://bun.com/install | bash -s "bun-v1.3.7"

ENV PATH="/root/.bun/bin:${PATH}"

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

# Frontend deps: baked into the image so the empty `bureaucat-vue-node` named
# volume (see docker-compose.yml) seeds from here on first run. This survives the
# `./:/app` bind mount, which would otherwise hide /app/web/node_modules at runtime.
COPY web/package.json web/bun.lock ./web/
RUN cd web && bun install --frozen-lockfile

CMD ["air", "-c", ".air.toml"]
